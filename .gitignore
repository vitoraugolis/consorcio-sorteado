# ============================================================
# .gitignore — Consórcio Sorteado
# NUNCA commite .env — ele contém credenciais reais
# ============================================================

# Credenciais e configuração local
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# Ambientes virtuais
.venv/
venv/
env/
ENV/

# Claude Code (configuração local — não commitar)
.claude/settings.local.json

# IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Testes e cobertura
.pytest_cache/
.coverage
htmlcov/

# Logs locais
*.log
logs/
